{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "color": "#0f172a",
          "name": "Ink",
          "slug": "ink"
        },
        {
          "color": "#334155",
          "name": "Slate",
          "slug": "slate"
        },
        {
          "color": "#f8fafc",
          "name": "Cloud",
          "slug": "cloud"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "white"
        },
        {
          "color": "#2563eb",
          "name": "Blue",
          "slug": "blue"
        },
        {
          "color": "#0f766e",
          "name": "Teal",
          "slug": "teal"
        },
        {
          "color": "#f59e0b",
          "name": "Amber",
          "slug": "amber"
        },
        {
          "color": "#e2e8f0",
          "name": "Line",
          "slug": "line"
        }
      ]
    },
    "custom": {
      "borderRadius": {
        "small": "4px",
        "medium": "8px",
        "large": "12px"
      },
      "shadow": {
        "soft": "0 16px 40px rgba(15, 23, 42, 0.08)"
      }
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    },
    "dimensions": {
      "aspectRatio": true,
      "defaultAspectRatios": true,
      "minHeight": true
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "name": "2XS",
          "size": "0.25rem",
          "slug": "20"
        },
        {
          "name": "XS",
          "size": "0.5rem",
          "slug": "30"
        },
        {
          "name": "S",
          "size": "0.75rem",
          "slug": "40"
        },
        {
          "name": "M",
          "size": "1rem",
          "slug": "50"
        },
        {
          "name": "L",
          "size": "1.5rem",
          "slug": "60"
        },
        {
          "name": "XL",
          "size": "2rem",
          "slug": "70"
        },
        {
          "name": "2XL",
          "size": "3rem",
          "slug": "80"
        },
        {
          "name": "3XL",
          "size": "4.5rem",
          "slug": "90"
        }
      ],
      "units": [
        "px",
        "rem",
        "em",
        "%",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "defaultFontSizes": false,
      "dropCap": false,
      "fontFamilies": [
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif",
          "name": "System Sans",
          "slug": "system-sans"
        },
        {
          "fontFamily": "ui-serif, Georgia, Cambria, \"Times New Roman\", Times, serif",
          "name": "System Serif",
          "slug": "system-serif"
        }
      ],
      "fontSizes": [
        {
          "fluid": false,
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "fluid": false,
          "name": "Base",
          "size": "1rem",
          "slug": "base"
        },
        {
          "fluid": false,
          "name": "Medium",
          "size": "1.125rem",
          "slug": "medium"
        },
        {
          "fluid": false,
          "name": "Large",
          "size": "1.5rem",
          "slug": "large"
        },
        {
          "fluid": false,
          "name": "Extra Large",
          "size": "2.5rem",
          "slug": "x-large"
        },
        {
          "fluid": false,
          "name": "Huge",
          "size": "3.25rem",
          "slug": "huge"
        }
      ]
    },
    "useRootPaddingAwareAlignments": true,
    "blocks": {
      "core/cover": {
        "color": {
          "background": true,
          "text": true
        },
        "dimensions": {
          "aspectRatio": true,
          "minHeight": true
        },
        "spacing": {
          "margin": true,
          "padding": true
        },
        "typography": {
          "fontSize": true,
          "lineHeight": true
        }
      },
      "core/heading": {
        "color": {
          "background": true,
          "text": true
        },
        "typography": {
          "fontSize": true,
          "fontWeight": true,
          "letterSpacing": true,
          "lineHeight": true,
          "textTransform": true
        }
      },
      "core/image": {
        "dimensions": {
          "aspectRatio": true,
          "minHeight": true
        }
      },
      "core/post-featured-image": {
        "dimensions": {
          "aspectRatio": true,
          "minHeight": true
        }
      },
      "core/post-title": {
        "color": {
          "background": true,
          "text": true
        },
        "spacing": {
          "margin": true,
          "padding": true
        },
        "typography": {
          "fontSize": true,
          "fontWeight": true,
          "letterSpacing": true,
          "lineHeight": true,
          "textTransform": true
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "var:preset|color|white",
      "text": "var:preset|color|ink"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "6px"
        },
        "color": {
          "background": "var:preset|color|blue",
          "text": "var:preset|color|white"
        },
        "spacing": {
          "padding": {
            "bottom": "0.75rem",
            "left": "1.1rem",
            "right": "1.1rem",
            "top": "0.75rem"
          }
        },
        "typography": {
          "fontWeight": "700"
        }
      },
      "caption": {
        "color": {
          "text": "var:preset|color|slate"
        },
        "typography": {
          "fontSize": "var:preset|font-size|small"
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "750",
          "lineHeight": "1.12"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|blue"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "left": "var:preset|spacing|80",
        "right": "var:preset|spacing|80"
      }
    },
    "typography": {
      "fontFamily": "var:preset|font-family|system-sans",
      "fontSize": "var:preset|font-size|base",
      "lineHeight": "1.65"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "header",
      "name": "header-centered",
      "title": "Header: Centered"
    },
    {
      "area": "header",
      "name": "header-minimal",
      "title": "Header: Minimal"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    },
    {
      "area": "footer",
      "name": "footer-columns",
      "title": "Footer: Columns"
    },
    {
      "area": "blog",
      "name": "blog-query",
      "title": "Blog Query"
    },
    {
      "area": "blog",
      "name": "blog-query-grid",
      "title": "Blog Query: Card Grid"
    },
    {
      "area": "blog",
      "name": "blog-query-list",
      "title": "Blog Query: Split List"
    },
    {
      "area": "blog",
      "name": "blog-query-magazine",
      "title": "Blog Query: Magazine Lead"
    },
    {
      "area": "blog",
      "name": "blog-query-compact",
      "title": "Blog Query: Compact Cards"
    },
    {
      "area": "blog",
      "name": "blog-toolbar",
      "title": "Blog Toolbar"
    },
    {
      "area": "sidebar",
      "name": "sidebar",
      "title": "Sidebar"
    }
  ],
  "customTemplates": [
    {
      "name": "page-landing",
      "postTypes": [
        "page"
      ],
      "title": "Landing Page"
    },
    {
      "name": "page-full-width",
      "postTypes": [
        "page"
      ],
      "title": "Full Width Page"
    },
    {
      "name": "single-product",
      "postTypes": [
        "product"
      ],
      "title": "Single Product"
    },
    {
      "name": "page-with-sidebar",
      "postTypes": [
        "page"
      ],
      "title": "Page with Sidebar"
    },
    {
      "name": "page-blank",
      "postTypes": [
        "page"
      ],
      "title": "Blank Canvas"
    },
    {
      "name": "single-magazine",
      "postTypes": [
        "post"
      ],
      "title": "Single: Magazine Hero"
    },
    {
      "name": "single-minimal",
      "postTypes": [
        "post"
      ],
      "title": "Single: Minimal Focus"
    },
    {
      "name": "single-feature",
      "postTypes": [
        "post"
      ],
      "title": "Single: Feature Split"
    },
    {
      "name": "single-with-sidebar",
      "postTypes": [
        "post"
      ],
      "title": "Single: With Sidebar"
    }
  ]
}
