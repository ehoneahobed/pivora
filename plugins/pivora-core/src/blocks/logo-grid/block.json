{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pivora/logo-grid",
	"version": "1.0.0",
	"title": "Logo Grid",
	"category": "pivora",
	"icon": "images-alt2",
	"description": "Trust bar with partner or client logos.",
	"keywords": [
		"logo",
		"trust",
		"clients",
		"partners"
	],
	"textdomain": "pivora-core",
	"attributes": {
		"heading": {
			"type": "string",
			"default": "Trusted by product teams, studios, and publishers"
		},
		"source": {
			"type": "string",
			"default": "manual"
		},
		"postsToShow": {
			"type": "number",
			"default": 6
		},
		"industrySlug": {
			"type": "string",
			"default": ""
		},
		"logos": {
			"type": "array",
			"default": [
				{
					"name": "Northline",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				},
				{
					"name": "Harbor Labs",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				},
				{
					"name": "Reyes Digital",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				},
				{
					"name": "Fieldnote",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				},
				{
					"name": "Summit Co.",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				},
				{
					"name": "Atlas Press",
					"url": "",
					"imageId": 0,
					"imageUrl": ""
				}
			]
		},
		"surfaceStyle": {
			"type": "string",
			"default": "card"
		}
	},
	"supports": {
		"html": false,
		"align": [
			"left",
			"center",
			"right",
			"wide",
			"full"
		],
		"color": {
			"text": true,
			"background": true,
			"link": true
		},
		"typography": {
			"fontSize": true,
			"fontFamily": true,
			"fontWeight": true,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"border": {
			"radius": true,
			"color": true,
			"width": true,
			"style": true
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
