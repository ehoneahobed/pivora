{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pivora/team-grid",
	"version": "1.0.0",
	"title": "Team Grid",
	"category": "pivora",
	"icon": "groups",
	"description": "Team member cards from the Team Members library.",
	"keywords": [ "team", "staff", "people", "grid" ],
	"textdomain": "pivora-core",
	"attributes": {
		"postsToShow": {
			"type": "number",
			"default": 3
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"surfaceStyle": {
			"type": "string",
			"default": "card"
		}
	},
	"supports": {
		"html": false,
		"align": [ "left", "center", "right", "wide", "full" ],
		"spacing": { "margin": true, "padding": true, "blockGap": true }
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
