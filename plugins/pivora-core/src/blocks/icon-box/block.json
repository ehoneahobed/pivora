{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "pivora/icon-box",
	"version": "1.0.0",
	"title": "Icon Box",
	"category": "pivora",
	"icon": "star-filled",
	"description": "Feature card with icon, title, and supporting text.",
	"keywords": [ "icon", "feature", "card" ],
	"textdomain": "pivora-core",
	"attributes": {
		"icon": {
			"type": "string",
			"default": "01"
		},
		"title": {
			"type": "string",
			"default": "Feature title"
		},
		"content": {
			"type": "string",
			"default": "Short supporting copy for this feature."
		}
	},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
