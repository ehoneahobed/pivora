{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pivora/process-steps",
  "version": "1.0.0",
  "title": "Process Steps",
  "category": "pivora",
  "icon": "editor-ol",
  "description": "Numbered process or timeline steps with title and description.",
  "keywords": [
    "process",
    "steps",
    "timeline",
    "workflow"
  ],
  "textdomain": "pivora-core",
  "attributes": {
    "steps": {
      "type": "array",
      "default": [
        {
          "number": "01",
          "title": "Discover",
          "description": "Audit goals, content, and conversion paths before you ship."
        },
        {
          "number": "02",
          "title": "Design",
          "description": "Compose layouts with patterns and blocks that stay editable."
        },
        {
          "number": "03",
          "title": "Launch",
          "description": "Publish with performance, accessibility, and SEO foundations in place."
        }
      ]
    },
    "layout": {
      "type": "string",
      "default": "vertical"
    },
    "surfaceStyle": {
      "type": "string",
      "default": "card"
    }
  },
  "supports": {
    "html": false,
    "align": [
      "left",
      "center",
      "right",
      "wide",
      "full"
    ],
    "color": {
      "text": true,
      "background": true,
      "link": true
    },
    "typography": {
      "fontSize": true,
      "fontFamily": true,
      "fontWeight": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "border": {
      "radius": true,
      "color": true,
      "width": true,
      "style": true
    }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php",
  "style": "file:./style-index.css"
}